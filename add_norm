    x = linear_attention_->forward(x, attn_metadata, kv_cache, input_params);
  }

  auto [new_x, new_res] = input_norm_->forward(x, residual.value());
  x = new_x;
  residual = new_res;

  // MLP forward
  if (moe_mlp_) {
    x = moe_mlp_(x, input_params);
  } else {
    x = mlp_(x);
  }



